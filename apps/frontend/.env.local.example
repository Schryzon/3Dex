# Copy to .env.local. Backend base URL must match your API (path often includes /api — see apiClient).
JWT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# Midtrans Snap (client key). Loaded in app/layout.tsx for window.snap — sandbox in dev, prod key when NODE_ENV=production.
NEXT_PUBLIC_SB_MIDTRANS_CLIENT_KEY=your_sandbox_key_here
NEXT_PUBLIC_PROD_MIDTRANS_CLIENT_KEY=your_production_key_here

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# USE_MOCK_DATA is in src/lib/api/services/product.service.ts (not an env var). Set it to false so cart/checkout hit the real API and Midtrans.
