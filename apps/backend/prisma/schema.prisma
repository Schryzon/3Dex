generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl", "windows"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  password           String?
  username           String            @unique
  role               Role              @default(CUSTOMER)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  avatar_url         String?
  bio                String?
  display_name       String?
  last_login_at      DateTime?
  location           String?
  social_artstation  String?
  social_behance     String?
  social_instagram   String?
  social_twitter     String?
  two_factor_enabled Boolean           @default(false)
  website            String?
  addresses          Json[]
  approved_at        DateTime?
  portfolio          Json[]
  provider_config    Json?
  rating             Float             @default(0)
  rejected_at        DateTime?
  review_count       Int               @default(0)
  status_history     Json[]
  google_id          String?           @unique
  show_nsfw          Boolean           @default(false)
  banner_url         String?
  account_status     Account_Status    @default(PENDING)
  dexie_enabled      Boolean           @default(true)
  phone_number       String?
  admin_audit_logs   Admin_Audit_Log[] @relation("admin_audit_logs")
  cart_items         Cart_Item[]
  collections        Collection[]
  following          Follow[]          @relation("follower")
  followers          Follow[]          @relation("following")
  models             Model[]           @relation("artist_models")
  notifications      Notification[]
  provider_orders    Order[]           @relation("provider_orders")
  orders             Order[]
  posts              Post[]
  post_comments      Post_Comment[]
  post_likes         Post_Like[]
  purchases          Purchase[]
  reports_given      Report[]
  reviews            Review[]
  given_reviews      User_Review[]     @relation("given_reviews")
  received_reviews   User_Review[]     @relation("received_reviews")
  wishlist           Wishlist[]
}

model Model {
  id               String                 @id @default(uuid())
  title            String
  description      String?
  price            Int
  artist_id        String
  created_at       DateTime               @default(now())
  file_url         String
  preview_url      String?
  category_id      String?
  avg_rating       Float                  @default(0)
  review_count     Int                    @default(0)
  gallery_urls     String[]
  is_nsfw          Boolean                @default(false)
  status           Model_Status           @default(PENDING)
  file_format      String                 @default("glb")
  is_printable     Boolean                @default(true)
  license          License_Type           @default(PERSONAL_USE)
  embedding        Unsupported("vector")?
  cart_items       Cart_Item[]
  collection_items Collection_Item[]
  artist           User                   @relation("artist_models", fields: [artist_id], references: [id])
  category         Category?              @relation(fields: [category_id], references: [id])
  order_items      Order_Item[]
  purchases        Purchase[]
  reviews          Review[]
  wishlist         Wishlist[]
  tags             Tag[]                  @relation("ModelToTag")
}

model Purchase {
  id         String       @id @default(uuid())
  created_at DateTime     @default(now())
  model_id   String?
  price_paid Int
  user_id    String
  license    License_Type @default(PERSONAL_USE)
  model      Model?       @relation(fields: [model_id], references: [id])
  user       User         @relation(fields: [user_id], references: [id])

  @@unique([user_id, model_id])
  @@index([user_id])
  @@index([model_id])
}

model Category {
  id         String   @id @default(uuid())
  name       String   @unique
  slug       String   @unique
  created_at DateTime @default(now())
  models     Model[]
}

model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  created_at DateTime @default(now())
  models     Model[]  @relation("ModelToTag")
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String?
  user_id    String
  model_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  model      Model    @relation(fields: [model_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, model_id])
}

model Wishlist {
  id         String   @id @default(uuid())
  user_id    String
  model_id   String
  created_at DateTime @default(now())
  model      Model    @relation(fields: [model_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, model_id])
}

model Cart_Item {
  id         String   @id @default(uuid())
  user_id    String
  model_id   String
  quantity   Int      @default(1)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  model      Model    @relation(fields: [model_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, model_id])
  @@index([user_id])
}

model Order {
  id                String       @id @default(uuid())
  user_id           String
  total_amount      Int          @default(0)
  status            Order_Status @default(PENDING)
  type              Order_Type   @default(ASSET)
  snap_token        String?
  snap_redirect_url String?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  courier_name      String?
  provider_id       String?
  shipping_address  Json?
  tracking_number   String?
  proof_urls        String[]     @default([])
  provider          User?        @relation("provider_orders", fields: [provider_id], references: [id])
  user              User         @relation(fields: [user_id], references: [id])
  items             Order_Item[]
  payments          Payment[]
}

model Order_Item {
  id           String       @id @default(uuid())
  order_id     String
  model_id     String?
  /// Unit price in IDR at time of purchase
  price        Int
  created_at   DateTime     @default(now())
  print_config Json?
  print_status Print_Status @default(PENDING)
  /// Line quantity (digital goods; total line = price * quantity)
  quantity     Int          @default(1)
  model        Model?       @relation(fields: [model_id], references: [id])
  order        Order        @relation(fields: [order_id], references: [id])
}

model Payment {
  id                 String   @id @default(uuid())
  order_id           String
  transaction_id     String   @unique
  payment_type       String
  gross_amount       Int
  transaction_status String
  fraud_status       String?
  raw_response       Json?
  created_at         DateTime @default(now())
  order              Order    @relation(fields: [order_id], references: [id])
}

model User_Review {
  id             String   @id @default(uuid())
  reviewer_id    String
  target_user_id String
  rating         Int
  comment        String?
  created_at     DateTime @default(now())
  reviewer       User     @relation("given_reviews", fields: [reviewer_id], references: [id])
  target_user    User     @relation("received_reviews", fields: [target_user_id], references: [id])

  @@unique([reviewer_id, target_user_id])
}

model Post {
  id            String         @id @default(uuid())
  user_id       String
  caption       String?
  media_urls    String[]
  like_count    Int            @default(0)
  comment_count Int            @default(0)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  is_nsfw       Boolean        @default(false)
  user          User           @relation(fields: [user_id], references: [id])
  comments      Post_Comment[]
  likes         Post_Like[]
}

model Post_Like {
  id         String   @id @default(uuid())
  user_id    String
  post_id    String
  created_at DateTime @default(now())
  post       Post     @relation(fields: [post_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, post_id])
}

model Post_Comment {
  id         String   @id @default(uuid())
  user_id    String
  post_id    String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  post       Post     @relation(fields: [post_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}

model Stats {
  id           String   @id @default(uuid())
  period_start DateTime
  period_end   DateTime
  data         Json
  created_at   DateTime @default(now())
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())
  follower     User     @relation("follower", fields: [follower_id], references: [id])
  following    User     @relation("following", fields: [following_id], references: [id])

  @@unique([follower_id, following_id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  message    String
  is_read    Boolean  @default(false)
  data       Json?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model Collection {
  id          String            @id @default(uuid())
  user_id     String
  name        String
  description String?
  is_public   Boolean           @default(true)
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  user        User              @relation(fields: [user_id], references: [id])
  items       Collection_Item[]
}

model Collection_Item {
  id            String     @id @default(uuid())
  collection_id String
  model_id      String
  added_at      DateTime   @default(now())
  collection    Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  model         Model      @relation(fields: [model_id], references: [id], onDelete: Cascade)

  @@unique([collection_id, model_id])
}

model Report {
  id          String        @id @default(uuid())
  reporter_id String
  target_type Report_Target
  model_id    String?
  post_id     String?
  comment_id  String?
  reason      String
  status      Report_Status @default(PENDING)
  created_at  DateTime      @default(now())
  reporter    User          @relation(fields: [reporter_id], references: [id])
}

model Admin_Audit_Log {
  id          String       @id @default(uuid())
  admin_id    String
  action      Audit_Action
  target_id   String
  target_type String
  reason      String
  metadata    Json?
  created_at  DateTime     @default(now())
  admin       User         @relation("admin_audit_logs", fields: [admin_id], references: [id])

  @@index([admin_id])
  @@index([created_at])
}

enum Role {
  CUSTOMER
  ARTIST
  ADMIN
  PROVIDER
}

enum Model_Status {
  PENDING
  APPROVED
  REJECTED
}

enum License_Type {
  PERSONAL_USE
  COMMERCIAL_USE
}

enum Order_Type {
  ASSET
  PRINT_JOB
}

enum Order_Status {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum Account_Status {
  PENDING
  APPROVED
  REJECTED
}

enum Print_Status {
  PENDING
  ACCEPTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Report_Target {
  MODEL
  POST
  COMMENT
}

enum Report_Status {
  PENDING
  REVIEWED
  DISMISSED
}

enum Audit_Action {
  DELETE_MODEL
  DELETE_POST
  DELETE_COMMENT
  BAN_USER
  REJECT_MODEL
  REJECT_USER
  APPROVE_USER
  USER_STEP_DOWN
}
