// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "windows"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ARTIST
  PROVIDER
  ADMIN
}

enum Model_Status {
  PENDING
  APPROVED
  REJECTED
}


model User {
  id        String  @id @default(uuid())
  email     String  @unique
  username  String  @unique
  password  String?
  google_id String? @unique
  role     Role   @default(CUSTOMER)

  // Account Status
  account_status Account_Status @default(PENDING) // Default pending for checks? Or APPROVED for Customer?
  // Logic: Service will handle defaults. Schema default can be PENDING.
  
  status_history Json[] // [{ status, timestamp, reason, admin_id }]
  approved_at    DateTime?
  rejected_at    DateTime?

  // Profile fields
  display_name String?
  bio          String?
  avatar_url   String?
  banner_url   String?
  location     String? // General location string
  website      String?
  
  // Structured Data
  addresses    Json[] // [{ label, street, city, region, country, zip, is_default }]
  portfolio    Json[] // [{ title, media_url, description }] (MinIO)
  provider_config Json? // { materials: [], colors: [], printer_types: [], max_size: [] }

  // Social links (stored as JSON for flexibility or separate fields)
  social_twitter    String?
  social_instagram  String?
  social_artstation String?
  social_behance    String?

  // Social Stats
  rating       Float @default(0) // Avg Rating
  review_count Int   @default(0)

  // Security
  two_factor_enabled Boolean @default(false)
  last_login_at      DateTime?
  show_nsfw          Boolean @default(false)
  
  models        Model[]        @relation("artist_models")
  purchases     Purchase[]
  reviews       Review[]       // Product Reviews given
  wishlist      Wishlist[]
  orders        Order[]        // Orders placed as Customer
  provider_orders Order[]      @relation("provider_orders") // Orders received as Provider

  cart_items    Cart_Item[]

  posts         Post[]
  post_likes    Post_Like[]
  post_comments Post_Comment[]
  
  received_reviews User_Review[] @relation("received_reviews")
  given_reviews    User_Review[] @relation("given_reviews")
  reports_given    Report[]

  followers     Follow[]       @relation("following")
  following     Follow[]       @relation("follower")
  notifications Notification[]
  collections   Collection[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Model {
  id          String  @id @default(uuid())
  title       String
  description String?
  price       Int // in IDR
  file_url    String
  preview_url String?
  gallery_urls String[]
  
  status      Model_Status @default(PENDING)
  is_nsfw     Boolean     @default(false)

  artist_id String
  artist    User   @relation("artist_models", fields: [artist_id], references: [id])

  category_id String?
  category    Category? @relation(fields: [category_id], references: [id])

  purchases  Purchase[]
  reviews    Review[]
  wishlist   Wishlist[]
  cart_items Cart_Item[]
  tags       Tag[]
  order_items Order_Item[]
  collection_items Collection_Item[]

  avg_rating   Float @default(0)
  review_count Int   @default(0)

  created_at DateTime @default(now())
}

enum License_Type {
  PERSONAL_USE
  COMMERCIAL_USE
}

model Purchase {
  id String @id @default(uuid())

  user_id  String
  model_id String

  user  User  @relation(fields: [user_id], references: [id])
  model Model @relation(fields: [model_id], references: [id])

  price_paid Int // in IDR
  license    License_Type @default(PERSONAL_USE)

  created_at DateTime @default(now())

  @@unique([user_id, model_id])
  @@index([user_id])
  @@index([model_id])
}

model Category {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  models Model[]

  created_at DateTime @default(now())
}

model Tag {
  id   String @id @default(uuid())
  name String @unique

  models Model[]

  created_at DateTime @default(now())
}

model Review {
  id      String @id @default(uuid())
  rating  Int    // 1-5
  comment String?

  user_id  String
  model_id String

  user  User  @relation(fields: [user_id], references: [id])
  model Model @relation(fields: [model_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  @@unique([user_id, model_id]) // One review per model per user
}

model Wishlist {
  id String @id @default(uuid())

  user_id  String
  model_id String

  user  User  @relation(fields: [user_id], references: [id])
  model Model @relation(fields: [model_id], references: [id])

  created_at DateTime @default(now())

  @@unique([user_id, model_id])
}

model Cart_Item {
  id String @id @default(uuid())

  user_id  String
  model_id String
  quantity Int @default(1)

  user  User  @relation(fields: [user_id], references: [id])
  model Model @relation(fields: [model_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, model_id])
  @@index([user_id])
}

enum Order_Type {
  ASSET
  PRINT_JOB
}

enum Order_Status {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum Account_Status {
  PENDING
  APPROVED
  REJECTED
}

enum Print_Status {
  PENDING
  ACCEPTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  // Provider Link (For Print Orders)
  provider_id String?
  provider    User?   @relation("provider_orders", fields: [provider_id], references: [id])

  total_amount Int          @default(0) // IDR
  status       Order_Status @default(PENDING) // Payment Status
  type         Order_Type   @default(ASSET)
  
  // Shipping & Tracking
  courier_name    String?
  tracking_number String?
  shipping_address Json? // Snapshot of address

  snap_token   String?
  snap_redirect_url String?

  items    Order_Item[]
  payments Payment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Order_Item {
  id String @id @default(uuid())

  order_id String
  order    Order  @relation(fields: [order_id], references: [id])

  model_id String?
  model    Model? @relation(fields: [model_id], references: [id])

  /// Unit price in IDR at time of purchase
  price Int
  /// Line quantity (digital goods; total line = price * quantity)
  quantity Int @default(1)

  // Print Config
  print_config Json? // { material, color, scale, ... }
  print_status Print_Status @default(PENDING)

  created_at DateTime @default(now())
}

model Payment {
  id String @id @default(uuid())

  order_id String
  order    Order  @relation(fields: [order_id], references: [id])

  transaction_id      String   @unique // Midtrans Transaction ID
  payment_type        String
  gross_amount        Int      // IDR
  transaction_status  String
  fraud_status        String?
  
  raw_response        Json?

  created_at DateTime @default(now())
}

model User_Review {
  id String @id @default(uuid())

  reviewer_id String
  reviewer    User   @relation("given_reviews", fields: [reviewer_id], references: [id])

  target_user_id String
  target_user    User   @relation("received_reviews", fields: [target_user_id], references: [id])

  rating  Int // 1-5
  comment String?

  created_at DateTime @default(now())

  @@unique([reviewer_id, target_user_id])
}

model Post {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  caption    String?
  media_urls String[] // Array of URLs

  is_nsfw    Boolean @default(false)

  like_count    Int @default(0)
  comment_count Int @default(0)

  likes    Post_Like[]
  comments Post_Comment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Post_Like {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  post_id String
  post    Post   @relation(fields: [post_id], references: [id])

  created_at DateTime @default(now())

  @@unique([user_id, post_id])
}

model Post_Comment {
  id String @id @default(uuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  post_id String
  post    Post   @relation(fields: [post_id], references: [id])

  content String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Stats {
  id String @id @default(uuid())

  period_start DateTime
  period_end   DateTime
  
  data Json // { top_models: [], top_artists: [], total_sales: 0 }

  created_at DateTime @default(now())
}

model Follow {
  id           String   @id @default(uuid())
  follower_id  String
  follower     User     @relation("follower", fields: [follower_id], references: [id])
  following_id String
  following    User     @relation("following", fields: [following_id], references: [id])
  created_at   DateTime @default(now())

  @@unique([follower_id, following_id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  type       String   // e.g., 'FOLLOW', 'MODEL_APPROVED', 'SALE', 'LIKE'
  title      String
  message    String
  is_read    Boolean  @default(false)
  data       Json?    // Optional payload
  created_at DateTime @default(now())

  @@index([user_id])
}

model Collection {
  id          String           @id @default(uuid())
  user_id     String
  user        User             @relation(fields: [user_id], references: [id])
  name        String
  description String?
  is_public   Boolean          @default(true)
  items       Collection_Item[]
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
}

model Collection_Item {
  id            String     @id @default(uuid())
  collection_id String
  collection    Collection @relation(fields: [collection_id], references: [id], onDelete: Cascade)
  model_id      String
  model         Model      @relation(fields: [model_id], references: [id], onDelete: Cascade)
  added_at      DateTime   @default(now())

  @@unique([collection_id, model_id])
}

enum Report_Target {
  MODEL
  POST
  COMMENT
}

enum Report_Status {
  PENDING
  REVIEWED
  DISMISSED
}

model Report {
  id String @id @default(uuid())

  reporter_id String
  reporter    User   @relation(fields: [reporter_id], references: [id])

  target_type Report_Target
  
  model_id   String?
  post_id    String?
  comment_id String?

  reason String

  status Report_Status @default(PENDING)

  created_at DateTime @default(now())
}

