@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "User" as U
participant "Frontend" as FE
participant "NotificationController" as NC
database "Database" as DB

U -> FE : click notification bell icon
FE -> NC : list_notifications(session_cookie)
NC -> DB : notification.findMany({\n  user_id, orderBy: created_at desc })
DB --> NC : Notification[]
NC --> FE : Notification[]
FE --> U : render notification panel\n(unread highlighted)

U -> FE : click a notification
FE -> NC : mark_read(notification_id)
NC -> DB : notification.update({ id, is_read: true })
DB --> NC : done
NC --> FE : 200 OK
FE --> U : notification dot decrements

U -> FE : click "Mark all as read"
FE -> NC : mark_all_read(session_cookie)
NC -> DB : notification.updateMany({\n  user_id, is_read: false },\n  { is_read: true })
DB --> NC : updated count
NC --> FE : 200 OK
FE --> U : all notification dots cleared
@enduml
