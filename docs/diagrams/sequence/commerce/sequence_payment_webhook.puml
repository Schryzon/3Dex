@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

participant "MidtransClient" as MT
participant "OrderController" as OC
participant "OrderService" as OS
database "Database" as DB
participant "NotificationService" as NS

MT -> OC : deliver_webhook({ order_id, transaction_status,\n  fraud_status, payment_type,\n  transaction_id, gross_amount })
OC -> OS : handle_payment_webhook(notification)
OS -> DB : order.findUnique({ id: order_id })\ninclude items
DB --> OS : Order | null
alt order not found
    OS --> OC : 404 Not Found
end
OS -> DB : payment.upsert({\n  transaction_id,\n  payment_type,\n  gross_amount,\n  transaction_status,\n  fraud_status,\n  raw_response })
DB --> OS : Payment

alt transaction_status = "settlement" OR "capture" AND fraud_status != "deny"
    OS -> DB : order.update({ status: PAID })
    loop for each order_item
        OS -> DB : purchase.upsert({\n  user_id, model_id,\n  price_paid, license })
        DB --> OS : Purchase
    end
    OS -> NS : notify_user(user_id, "Your purchase is complete!")
    NS -> DB : notification.create(...)
else transaction_status = "deny" OR "cancel" OR "expire"
    OS -> DB : order.update({ status: CANCELLED })
    OS -> NS : notify_user(user_id, "Payment failed or cancelled.")
    NS -> DB : notification.create(...)
else transaction_status = "pending"
    OS -> DB : order.update({ status: PENDING })
end

OS --> OC : { message: "ok" }
OC --> MT : 200 OK
@enduml
