@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "User" as U
participant "Frontend" as FE
participant "AuthController" as AC
participant "StorageService" as SS
database "Database" as DB

U -> FE : app mounts / page refresh
FE -> AC : get_me(session_cookie)
AC -> AC : auth_middleware.decode_cookie_jwt(session_cookie)
alt no cookie or invalid token
    AC --> FE : 401 Unauthorized
    FE -> FE : clear AuthContext
    FE --> U : show guest state
end
AC -> DB : user.findUnique({ id: token.id })
DB --> AC : User | null
alt user deleted
    AC --> FE : 404 Not Found
    FE --> U : logout + redirect
end
AC -> AC : strip_sensitive_fields(password, google_id)
AC -> AC : sign_token({ id, email, username, role })
AC -> AC : set_session_cookie(fresh_token)
AC -> SS : sign_user_urls(safe_user)
SS --> AC : signed avatar_url, banner_url
AC --> FE : 200 full user object
FE -> FE : hydrate AuthContext
FE --> U : user-aware UI ready
@enduml
