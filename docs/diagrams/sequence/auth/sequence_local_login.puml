@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120
skinparam sequenceParticipant underline

actor "User" as U
participant "Frontend" as FE
participant "AuthController" as AC
participant "AuthService" as AS
database "Database" as DB
participant "StorageService" as SS

U -> FE : submit email + password
FE -> AC : login(email, password)
AC -> AC : validate_fields_present(email, password)
alt missing fields
    AC --> FE : 400 Missing fields!
    FE --> U : show error
end
AC -> AS : login_user(email, password)
AS -> DB : user.findUnique({ email })
DB --> AS : User | null
alt user not found
    AS --> AC : null
    AC --> FE : 401 Invalid credentials!
    FE --> U : show error
end
AS -> AS : bcrypt.compare(password, user.password)
alt wrong password
    AS --> AC : null
    AC --> FE : 401 Invalid credentials!
    FE --> U : show error
end
AS -> DB : user.update({ last_login_at: now })
AS --> AC : User
AC -> AC : sign_token({ id, email, username, role })
AC -> AC : set_session_cookie(token, httpOnly, sameSite=lax, maxAge=7d)
AC -> SS : sign_user_urls(user)
SS --> AC : user with signed avatar_url
AC --> FE : 200 { user }
FE -> FE : store user in AuthContext
FE --> U : redirect to /
@enduml
