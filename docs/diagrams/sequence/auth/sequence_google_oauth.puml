@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "User" as U
participant "Frontend" as FE
participant "OAuthClient" as G
participant "AuthController" as AC
participant "AuthService" as AS
database "Database" as DB

U -> FE : click "Continue with Google"
FE -> G : initiate Google One Tap / OAuth prompt
G --> FE : credential (ID token string)
FE -> AC : google_login(credential)
AC -> AS : google_login(credential)
AS -> G : verify_id_token(credential)
G --> AS : GooglePayload { sub, email, name, picture }
AS -> DB : user.findUnique({ google_id: sub })
alt user exists
    DB --> AS : existing User
else user does not exist
    AS -> DB : user.findUnique({ email })
    alt email already registered locally
        DB --> AS : User (no google_id)
        AS -> DB : user.update({ google_id: sub })
        DB --> AS : Updated User
    else brand new user
        AS -> DB : user.create({ email, username: auto-generated, google_id,\n  role: CUSTOMER, account_status: APPROVED })
        DB --> AS : new User
        AS --> AC : { user, isNew: true }
    end
end
AS --> AC : { user, isNew }
AC -> AC : sign_token({ id, email, username, role })
AC -> AC : set_session_cookie(token)
alt isNew = true
    AC --> FE : 200 { user, needs_username: true }
    FE --> U : redirect to /complete-profile
else
    AC --> FE : 200 { user, needs_username: false }
    FE --> U : redirect to /
end
@enduml
