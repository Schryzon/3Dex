@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "User" as U
participant "Frontend" as FE
participant "ModelController" as MC
participant "StorageService" as SS
participant "StorageClient" as S3
database "Database" as DB

U -> FE : type in search box / apply filters
FE -> MC : list_models(search, category_id, min_price, max_price,\n  sort, page, limit)
MC -> MC : parse_user_context(user):\n  is_self = (user && artist_id == user.id)\n  is_admin = (user.role == ADMIN)
MC -> MC : build_where_clause():\n  status: APPROVED (unless admin/self)\n  artist.role: ARTIST (unless admin/self)\n  is_nsfw: false (unless nsfw=true in query)\n  OR search across title, description, tags, category
MC -> MC : build_order_by(sort):\n  newest|oldest|price_asc|price_desc|rating|popular
MC -> MC : build_pagination(page, limit):\n  skip = (page - 1) * limit, take = limit
MC -> DB : model.findMany({ where, orderBy, take, skip,\n  include: { artist, category, tags } })
DB --> MC : Model[]
MC -> DB : model.count({ where })
DB --> MC : total count
loop for each model
    MC -> SS : get_download_url(model.preview_url)
    SS -> S3 : presign_get_url(key)
    S3 --> SS : signed URL
    SS --> MC : signed preview_url
    MC -> SS : get_download_url(model.file_url)
    SS --> MC : signed file_url
    MC -> SS : sign_user_urls(artist)
    SS --> MC : artist with signed avatar_url
end
MC --> FE : { data: Model[], meta: { total, page, limit, pages } }
FE --> U : render paginated model grid
@enduml
