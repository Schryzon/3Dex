@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "Artist" as A
participant "Frontend" as FE
participant "StorageController" as SC
participant "StorageService" as SS
participant "StorageClient" as S3
participant "ModelController" as MC
participant "ModelService" as MS
participant "EmbeddingService" as ES
database "Database" as DB

A -> FE : fill upload form\n(title, price, tags, file, preview)
FE -> SC : get_upload_url(filename: model.glb, content_type: model/gltf-binary)
SC -> SS : get_upload_url(filename, content_type)
SS -> S3 : presign_put_url(key)
S3 --> SS : presigned_url + key
SS --> SC : { upload_url, key }
SC --> FE : { upload_url, key }

FE -> S3 : put(presigned_url, raw_glb_binary)
S3 --> FE : 200 OK

FE -> SC : get_upload_url(filename: preview.webp, content_type: image/webp)
SC --> FE : { upload_url: preview_url, key: preview_key }
FE -> S3 : put(presigned_url, preview_image)
S3 --> FE : 200 OK

FE -> MC : upload_model({ title, price, file_url: key, preview_url: preview_key,\n  artist_id, category, tags, license, is_printable, is_nsfw })
MC -> MC : validate_required_fields()
MC -> MC : extract_file_format(file_url)
alt not .glb or .gltf
    MC --> FE : 400 Invalid file format
end
MC -> DB : category.findUnique({ slug })
DB --> MC : Category | null
MC -> MS : create_model({ ...data, category_id, file_format })
MS -> DB : model.create({ ... })
DB --> MS : Model (status: PENDING)
MS --> MC : Model
MC -> ES : embed_and_save_model(model.id)  'fire & forget
ES -> DB : model.findUnique (get title + description)
ES -> ES : encode_text(title + description)\n  via all-MiniLM-L6-v2
ES -> DB : model.update({ embedding: vector })
MC --> FE : 201 { model }
FE --> A : "Model uploaded! Pending admin review."
@enduml
