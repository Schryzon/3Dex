@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "User (Artist/Provider)" as U
participant "Frontend" as FE
participant "PostController" as PC
participant "StorageController" as SC
participant "StorageClient" as S3
database "Database" as DB

U -> FE : open Community page
FE -> PC : get_feed_posts()
PC -> DB : post.findMany(orderBy: created_at desc)\ninclude user, _count(likes, comments), likes(where: current_user)
DB --> PC : Post[]
PC -> PC : map_flags(posts):\n  add is_liked, is_followed per post
PC --> FE : feed Post[]
FE --> U : render feed

U -> FE : click "New Post"
FE --> U : upload media form
U -> FE : select images + enter caption + submit
FE -> SC : get_upload_url(filename, content_type)  'for each image
SC --> FE : presigned URLs
FE -> S3 : put(presigned_url, image_binary)  'for each image
FE -> PC : create_post({ caption, media_urls: [keys], is_nsfw })
PC -> PC : check_role(user.role)\n  only ARTIST or PROVIDER allowed
alt role is CUSTOMER or ADMIN
    PC --> FE : 403 Only Artists and Providers can post!
    FE --> U : access denied
end
PC -> PC : validate_media_urls_not_empty(media_urls)
PC -> DB : post.create({ user_id, caption, media_urls, is_nsfw })
DB --> PC : Post
PC --> FE : 201 Post
FE --> U : post appears in feed

U -> FE : click heart icon on a post
FE -> PC : toggle_like(post_id, session_cookie)
PC -> DB : post_Like.findUnique({ user_id_post_id })
DB --> PC : PostLike | null
alt like exists (toggle off)
    PC -> DB : post_Like.delete({ user_id_post_id })
    PC -> DB : post.update({ like_count: decrement })
    PC --> FE : { message: "Unliked" }
else no like (toggle on)
    PC -> DB : post_Like.create({ user_id, post_id })
    PC -> DB : post.update({ like_count: increment })
    PC --> FE : { message: "Liked" }
end
FE --> U : heart icon toggled

U -> FE : type comment + submit
FE -> PC : add_comment(post_id, content)
PC -> PC : validate_content_not_empty(content)
PC -> DB : post_Comment.create({ user_id, post_id, content })
DB --> PC : Post_Comment
PC -> DB : post.update({ comment_count: increment })
PC --> FE : Post_Comment
FE --> U : comment appears below post
@enduml
