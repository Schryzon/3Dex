@startuml
skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "Customer" as C
participant "Frontend" as FE
participant "ReviewController" as RC
database "Database" as DB

C -> FE : open artist/provider profile
FE -> RC : check_review_eligibility(target_user_id, session_cookie)
RC -> DB : user_Review.findUnique({\n  reviewer_id_target_user_id })
DB --> RC : existingReview | null
alt already reviewed
    RC --> FE : { eligible: false, reason: ALREADY_REVIEWED }
    FE --> C : hide review button
end
RC -> DB : purchase.findFirst({ user_id, model.artist_id: target })
DB --> RC : Purchase | null
RC -> DB : order.findFirst({ user_id, provider_id: target, status: PAID, type: PRINT_JOB })
DB --> RC : Order | null
alt no transaction at all
    RC --> FE : { eligible: false, reason: NO_TRANSACTION }
    FE --> C : show "Buy from this creator first"
end
RC --> FE : { eligible: true }
FE --> C : show review form

C -> FE : submit { target_user_id, rating, comment }
FE -> RC : add_user_review(target_user_id, rating, comment)
RC -> RC : validate_not_self_review(reviewer_id, target_user_id)
RC -> RC : validate_rating(rating, min=1, max=5)
RC -> DB : re-check purchase / print order existence
RC -> DB : user_Review.create({ reviewer_id, target_user_id, rating, comment })
DB --> RC : User_Review
RC -> DB : user_Review.aggregate({ target_user_id })\n_avg.rating, _count.rating
DB --> RC : aggregated stats
RC -> DB : user.update({ target_user_id, rating, review_count })
DB --> RC : updated User
RC --> FE : 200 User_Review
FE --> C : review submitted, profile rating updated
@enduml
