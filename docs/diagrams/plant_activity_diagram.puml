@startuml
|Customer|
start
:Add Model to Cart;
:Proceed to Checkout;

|System|
:Initialize Order (Status: PENDING);
:Request Payment Gateway Token;

|Midtrans API|
:Generate Snap Token;

|System|
:Attach Token to Order;

|Customer|
:Open Midtrans Checkout UI;
:Complete Payment Process;

|Midtrans API|
:Send Payment Notification (Webhook);

|System|
if (Transaction Status == 'settlement') then (yes)
  :Update Payment to 'SUCCESS';
  :Update Order to 'PAID';
  
  |Customer|
  :Receive Order Confirmation Email;
  :Unlock Model Access / Download;
else (no)
  |System|
  :Update Payment to 'FAILED';
  :Update Order to 'FAILED';
  
  |Customer|
  :Receive Payment Failure Notification;
endif

stop
@enduml
