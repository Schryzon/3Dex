@startuml
skinparam linetype ortho
skinparam classAttributeIconSize 0

class User {
  + String id
  + String email
  + String username
  + String password
  + String google_id
  + Role role
  + Account_Status account_status
  + Json[] status_history
  + DateTime approved_at
  + DateTime rejected_at
  + String display_name
  + String bio
  + String avatar_url
  + String banner_url
  + String location
  + String website
  + String phone_number
  + Json[] addresses
  + Json[] portfolio
  + Json provider_config
  + String social_twitter
  + String social_instagram
  + String social_artstation
  + String social_behance
  + Float rating
  + Int review_count
  + Boolean two_factor_enabled
  + DateTime last_login_at
  + Boolean show_nsfw
  + Boolean dexie_enabled
  + DateTime created_at
  + DateTime updated_at
  + register()
  + login()
  + updateProfile(data: User)
  + changePassword(new_password: String)
  + deleteAccount()
}

class Customer extends User {
  + addToCart(model_id: String, qty: Int)
  + checkout()
  + purchaseModel(model_id: String)
  + writeReview(model_id: String, rating: Int)
}

class Artist extends User {
  + uploadModel(data: Model)
  + updateModel(id: String, data: Model)
  + deleteModel(id: String)
  + viewSalesStats()
}

class Provider extends User {
  + acceptPrintJob(order_id: String)
  + updatePrintStatus(order_id: String, status: Print_Status)
  + updateProviderConfig(config: Json)
}

class Admin extends User {
  + approveModel(id: String)
  + rejectModel(id: String)
  + approveUser(id: String)
  + rejectUser(id: String)
  + suspendUser(id: String)
  + generatePlatformReport()
  + viewAuditLogs()
}

class Model {
  + String id
  + String title
  + String description
  + Int price
  + String file_url
  + String preview_url
  + String[] gallery_urls
  + Model_Status status
  + Boolean is_nsfw
  + License_Type license
  + Boolean is_printable
  + String file_format
  + Unsupported vector_embedding
  + String artist_id
  + String category_id
  + Float avg_rating
  + Int review_count
  + DateTime created_at
  + updateStatus(status: Model_Status)
  + calculateAvgRating() : Float
  + incrementReviewCount()
}

class Purchase {
  + String id
  + String user_id
  + String model_id
  + Int price_paid
  + License_Type license
  + DateTime created_at
  + verifyLicense(license: License_Type) : Boolean
}

class Category {
  + String id
  + String name
  + String slug
  + DateTime created_at
}

class Tag {
  + String id
  + String name
  + DateTime created_at
}

class Review {
  + String id
  + Int rating
  + String comment
  + String user_id
  + String model_id
  + DateTime created_at
  + DateTime updated_at
  + updateComment(content: String)
}

class Wishlist {
  + String id
  + String user_id
  + String model_id
  + DateTime created_at
  + moveToCart()
}

class Cart_Item {
  + String id
  + String user_id
  + String model_id
  + Int quantity
  + DateTime created_at
  + DateTime updated_at
  + updateQuantity(qty: Int)
}

class Order {
  + String id
  + String user_id
  + String provider_id
  + Int total_amount
  + Order_Status status
  + Order_Type type
  + String courier_name
  + String tracking_number
  + Json shipping_address
  + String[] proof_urls
  + String snap_token
  + String snap_redirect_url
  + DateTime created_at
  + DateTime updated_at
  + calculateTotal()
  + updateStatus(status: Order_Status)
  + generateSnapToken()
}

class Order_Item {
  + String id
  + String order_id
  + String model_id
  + Int price
  + Int quantity
  + Json print_config
  + Print_Status print_status
  + DateTime created_at
  + updatePrintConfig(config: Json)
}

class Payment {
  + String id
  + String order_id
  + String transaction_id
  + String payment_type
  + Int gross_amount
  + String transaction_status
  + String fraud_status
  + Json raw_response
  + DateTime created_at
  + processTransaction()
  + verifyFraudStatus()
  + refund()
}

class User_Review {
  + String id
  + String reviewer_id
  + String target_user_id
  + Int rating
  + String comment
  + DateTime created_at
  + updateReviewData(rating: Int, comment: String)
}

class Post {
  + String id
  + String user_id
  + String caption
  + String[] media_urls
  + Boolean is_nsfw
  + Int like_count
  + Int comment_count
  + DateTime created_at
  + DateTime updated_at
  + addLike()
  + removeLike()
  + addComment(content: String)
}

class Post_Like {
  + String id
  + String user_id
  + String post_id
  + DateTime created_at
}

class Post_Comment {
  + String id
  + String user_id
  + String post_id
  + String content
  + DateTime created_at
  + DateTime updated_at
  + editContent(content: String)
}

class Stats {
  + String id
  + DateTime period_start
  + DateTime period_end
  + Json data
  + DateTime created_at
  + triggerAggregation()
}

class Follow {
  + String id
  + String follower_id
  + String following_id
  + DateTime created_at
}

class Notification {
  + String id
  + String user_id
  + String type
  + String title
  + String message
  + Boolean is_read
  + Json data
  + DateTime created_at
  + markAsRead()
}

class Collection {
  + String id
  + String user_id
  + String name
  + String description
  + Boolean is_public
  + DateTime created_at
  + DateTime updated_at
  + addItem(model_id: String)
  + removeItem(model_id: String)
}

class Collection_Item {
  + String id
  + String collection_id
  + String model_id
  + DateTime added_at
}

class Report {
  + String id
  + String reporter_id
  + Report_Target target_type
  + String model_id
  + String post_id
  + String comment_id
  + String reason
  + Report_Status status
  + DateTime created_at
  + reviewReport(status: Report_Status)
}

class Admin_Audit_Log {
  + String id
  + String admin_id
  + Audit_Action action
  + String target_id
  + String target_type
  + String reason
  + Json metadata
  + DateTime created_at
}

User *-- Cart_Item : "owns"
User *-- Wishlist : "owns"
Order *-- Order_Item : "contains"
Order *-- Payment : "processes"
Post *-- Post_Like : "has"
Post *-- Post_Comment : "has"
Collection *-- Collection_Item : "contains"
User *-- Post : "creates"
User *-- Review : "writes"

Category o-- Model : "categorizes"
Model o-- Order_Item : "referenced in"
Model o-- Collection_Item : "referenced in"
Model o-- Review : "has"
Model o-- Purchase : "has"
Model o-- Wishlist : "in wishlist"
Model o-- Cart_Item : "in cart"

Artist "1" --> "*" Model : creates
Customer "1" --> "*" Purchase : purchases
Customer "1" --> "*" Order : places
Provider "1" --> "*" Order : provider_for
User "1" --> "*" User_Review : receives
User "1" --> "*" User_Review : gives
User "1" --> "*" Follow : follows
User "1" --> "*" Notification : receives
User "1" --> "*" Collection : manages
User "1" --> "*" Report : submits
User "1" --> "*" Admin_Audit_Log : performs_action

Model "*" --> "*" Tag : tagged_with

@enduml
