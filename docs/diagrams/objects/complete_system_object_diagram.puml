' --- Defining the Relationships ---
artist --> model : creates
category o-- model : categorizes
model --> tag1 : tagged_with
model --> tag2 : tagged_with

customer --> purchase : purchases
model o-- purchase : has

customer *-- cart_item : owns
model o-- cart_item : in cart

customer *-- wishlist : owns
model o-- wishlist : in wishlist

customer --> order : places
provider --> order : provider_for
order *-- order_item : contains
model o-- order_item : referenced in
order *-- payment : processes

customer *-- review : writes
model o-- review : has

customer --> user_review : gives
user_review --> artist : receives

artist *-- post : creates
customer --> like : creates
customer --> comment : creates
post *-- like : has
post *-- comment : has

customer --> follow : follows
follow --> artist : following

customer --> collection : manages
collection *-- col_item : contains
model o-- col_item : referenced in

customer --> report : submits
report --> post : target

artist *-- notification : receives

admin --> audit_log : performs_action
audit_log --> model : target

@enduml
